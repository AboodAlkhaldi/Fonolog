{
  "expo": {
    "name": "Fonolog",
    "slug": "fonolog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "okuma",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8E7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.villaakademia.fonolog",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Fonolog, telaffuzunu değerlendirmek için mikrofona erişim ister.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.villaakademia.fonolog",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF8E7"
      },
      "permissions": [
        "RECORD_AUDIO",
        "VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "RECORD_AUDIO",
        "VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-audio",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FFC857"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF8E7",
          "image": "./assets/images/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ad191aaa-7dc9-4f4d-8543-4bbbc3ea6e26"
      }
    },
    "owner": "aboodalkhaldis-organization",
    "runtimeVersion": "1.0.0" ,
    "updates": {
      "url": "https://u.expo.dev/ad191aaa-7dc9-4f4d-8543-4bbbc3ea6e26"
    }
  }
}
